# Normalize all text files to LF in the repo; Git checks them out with the
# platform's native ending on Windows and as LF on Linux/macOS.
* text=auto

# Files that must stay LF regardless of platform
*.sh    text eol=lf
*.cs    text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.xaml  text eol=lf
*.xml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.resw  text eol=lf
*.config text eol=lf
*.manifest text eol=lf
*.appxmanifest text eol=lf
*.pubxml text eol=lf
*.editorconfig text eol=lf

# Explicit binary — never touch
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.xlsx binary
*.pdf binary
