<Page x:Class="FtdModularLabs.App.Presentation.DesignsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FtdModularLabs.App.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      NavigationCacheMode="Required"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds" Padding="24" RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="{Binding Title}" Style="{StaticResource TitleTextBlockStyle}" />

    <!-- Create a new design -->
    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
            CornerRadius="8" Padding="16">
      <StackPanel Spacing="8">
        <TextBlock Text="New design" Style="{StaticResource SubtitleTextBlockStyle}" />
        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" PlaceholderText="Design name (e.g. Valiant-class Battleship)"
                   Text="{Binding NewDesignName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          <ComboBox Grid.Column="1" MinWidth="180"
                    ItemsSource="{Binding DesignTemplates}"
                    DisplayMemberPath="Display"
                    SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}" />
          <Button Grid.Column="2" Content="Create" Command="{Binding CreateCommand}"
                  Style="{StaticResource AccentButtonStyle}" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Existing designs -->
    <ListView Grid.Row="2"
              ItemsSource="{Binding Designs}"
              SelectedItem="{Binding SelectedDesign, Mode=TwoWay}"
              DoubleTapped="OnDesignDoubleTapped"
              ToolTipService.ToolTip="Double-click a design to open it"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Margin="0,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding VehicleClass}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
            </StackPanel>
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7"
                       Text="{Binding Modules.Count}" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
      <Button Content="Open" Command="{Binding OpenCommand}" Style="{StaticResource AccentButtonStyle}" />
      <Button Content="Duplicate" Command="{Binding DuplicateCommand}" />
      <Button Content="Delete" Command="{Binding DeleteCommand}" />
      <Button Content="Manage templates" Command="{Binding ManageTemplatesCommand}" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0" />
    </StackPanel>
  </Grid>
</Page>
