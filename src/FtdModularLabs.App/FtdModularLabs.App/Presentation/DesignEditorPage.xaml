<Page x:Class="FtdModularLabs.App.Presentation.DesignEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FtdModularLabs.App.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      NavigationCacheMode="Required"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <!-- The detail pane for the selected module: generic form + compute, or a "coming soon" notice. -->
    <DataTemplate x:Key="ModuleEditorTemplate">
      <ScrollViewer>
        <StackPanel Spacing="12" Margin="24" MaxWidth="680" HorizontalAlignment="Left">
          <TextBlock Text="{Binding TypeName}" Style="{StaticResource TitleTextBlockStyle}" />
          <TextBlock Text="{Binding Category}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
          <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.75" />

          <!-- Calculator-less types -->
          <Border Visibility="{Binding ComingSoon, Converter={StaticResource BoolToVisibility}}"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                  CornerRadius="8" Padding="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Calculator coming soon" Style="{StaticResource SubtitleTextBlockStyle}" />
              <TextBlock TextWrapping="Wrap" Opacity="0.75"
                         Text="This subsystem type has no optimizer yet. You can still name, organize, and persist it as part of the design." />
            </StackPanel>
          </Border>

          <!-- Calculator-backed types -->
          <StackPanel Spacing="12" Visibility="{Binding HasCalculator, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Inputs" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <ItemsControl ItemsSource="{Binding Fields}"
                          ItemTemplateSelector="{StaticResource ParameterTemplateSelector}" />

            <Button Content="Compute" Command="{Binding ComputeCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    AutomationProperties.AutomationId="ComputeButton" />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="OrangeRed" TextWrapping="Wrap" />

            <StackPanel Spacing="8" Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="Results" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
              <ItemsControl ItemsSource="{Binding Summary}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="16,12" Margin="0,0,12,0" MinWidth="140">
                      <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Label}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                        <TextBlock Text="{Binding Value}" Style="{StaticResource SubtitleTextBlockStyle}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <ItemsControl ItemsSource="{Binding Tables}" ItemTemplate="{StaticResource ResultTableTemplate}" />

              <TextBlock Text="{Binding Notes}" Opacity="0.6" FontStyle="Italic"
                         TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>
  </Page.Resources>

  <Grid x:Name="EditorRoot" utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" ColumnSpacing="8" Padding="8,6" Background="{ThemeResource LayerFillColorDefaultBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Command="{Binding BackCommand}"
              VerticalAlignment="Center" CornerRadius="8"
              Padding="12,6" FontSize="18"
              ToolTipService.ToolTip="Save and return to designs"
              AutomationProperties.Name="Back to designs">
        <TextBlock Text="&#x2190;" FontSize="20" />
      </Button>
      <TextBlock Grid.Column="1" Text="Edit Design" VerticalAlignment="Center"
                 Style="{StaticResource TitleTextBlockStyle}" />
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="360" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Master: design fields + module list + add-module -->
      <ScrollViewer Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <StackPanel Spacing="10" Margin="16">
          <TextBlock Text="Design" Style="{StaticResource SubtitleTextBlockStyle}" />
          <TextBox Header="Name" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          <TextBox Header="Vehicle class" Text="{Binding VehicleClass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Text="Add module" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
          <ComboBox Header="Subsystem type" HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Types}" DisplayMemberPath="Display"
                    SelectedItem="{Binding SelectedType, Mode=TwoWay}" />
          <ComboBox Header="Preset" HorizontalAlignment="Stretch"
                    ItemsSource="{Binding ModuleTemplates}" DisplayMemberPath="Display"
                    SelectedItem="{Binding SelectedModuleTemplate, Mode=TwoWay}" />
          <TextBox PlaceholderText="Module name (optional)"
                   Text="{Binding NewModuleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          <Button Content="Add module" Command="{Binding AddModuleCommand}" HorizontalAlignment="Stretch" />

          <TextBlock Text="Modules" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
          <ListView ItemsSource="{Binding Modules}"
                    SelectedItem="{Binding SelectedModuleItem, Mode=TwoWay}"
                    DoubleTapped="OnModuleDoubleTapped"
                    ToolTipService.ToolTip="Double-click a module to open it"
                    MaxHeight="360">
            <ListView.ItemTemplate>
              <DataTemplate>
                <Grid ColumnSpacing="4" Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding TypeName}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="▲" FontSize="10"
                          Command="{Binding DataContext.MoveModuleUpCommand, ElementName=EditorRoot}" CommandParameter="{Binding}" />
                  <Button Grid.Column="2" Content="▼" FontSize="10"
                          Command="{Binding DataContext.MoveModuleDownCommand, ElementName=EditorRoot}" CommandParameter="{Binding}" />
                  <Button Grid.Column="3" Content="✕" FontSize="10"
                          Command="{Binding DataContext.RemoveModuleCommand, ElementName=EditorRoot}" CommandParameter="{Binding}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource AccentButtonStyle}" />
            <Button Content="Save as template" Command="{Binding SaveAsTemplateCommand}" />
          </StackPanel>
          <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>
      </ScrollViewer>

      <!-- Detail: the selected module's editor -->
      <Grid Grid.Column="1">
        <TextBlock Text="Double-click a module to edit it."
                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"
                   Visibility="{Binding HasEnteredModule, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}" />
        <StackPanel Visibility="{Binding HasEnteredModule, Converter={StaticResource BoolToVisibility}}">
          <TextBox Header="Module name" Margin="24,16,24,0" MaxWidth="680" HorizontalAlignment="Left"
                   Text="{Binding EnteredModule.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          <ContentControl HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                          Content="{Binding ModuleEditor}"
                          ContentTemplate="{StaticResource ModuleEditorTemplate}" />
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Page>
