<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:FtdModularLabs.App.Presentation">

  <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />

  <!-- Editor templates, one per ParameterKind. Each binds the field's Value two-way. -->
  <DataTemplate x:Key="NumberFieldTemplate">
    <StackPanel Spacing="2" Margin="0,0,0,12">
      <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource CaptionTextBlockStyle}" />
      <NumberBox Value="{Binding Value, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
      <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                 Opacity="0.6" TextWrapping="Wrap" />
    </StackPanel>
  </DataTemplate>

  <DataTemplate x:Key="EnumFieldTemplate">
    <StackPanel Spacing="2" Margin="0,0,0,12">
      <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource CaptionTextBlockStyle}" />
      <ComboBox ItemsSource="{Binding Options}"
                SelectedItem="{Binding Value, Mode=TwoWay}"
                HorizontalAlignment="Stretch" />
      <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                 Opacity="0.6" TextWrapping="Wrap" />
    </StackPanel>
  </DataTemplate>

  <DataTemplate x:Key="BooleanFieldTemplate">
    <StackPanel Spacing="2" Margin="0,0,0,12">
      <ToggleSwitch Header="{Binding DisplayLabel}" IsOn="{Binding Value, Mode=TwoWay}" />
      <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                 Opacity="0.6" TextWrapping="Wrap" />
    </StackPanel>
  </DataTemplate>

  <DataTemplate x:Key="TextFieldTemplate">
    <StackPanel Spacing="2" Margin="0,0,0,12">
      <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource CaptionTextBlockStyle}" />
      <TextBox Text="{Binding Value, Mode=TwoWay}" />
      <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                 Opacity="0.6" TextWrapping="Wrap" />
    </StackPanel>
  </DataTemplate>

  <!-- Armor builder: an ordered, selectable stack of layers (the target composition). -->
  <DataTemplate x:Key="LayerStackFieldTemplate">
    <StackPanel Spacing="6" Margin="0,0,0,12">
      <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource CaptionTextBlockStyle}" />
      <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ComboBox Grid.Column="0" ItemsSource="{Binding Options}"
                  SelectedItem="{Binding SelectedOptionToAdd, Mode=TwoWay}"
                  HorizontalAlignment="Stretch" />
        <Button Grid.Column="1" Content="Add layer" Command="{Binding AddLayerCommand}" />
      </Grid>
      <ItemsControl ItemsSource="{Binding Stack}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid ColumnSpacing="4" Margin="0,2"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  Padding="8,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="▲" FontSize="10"
                      Command="{Binding Owner.MoveLayerUpCommand}" CommandParameter="{Binding}" />
              <Button Grid.Column="2" Content="▼" FontSize="10"
                      Command="{Binding Owner.MoveLayerDownCommand}" CommandParameter="{Binding}" />
              <Button Grid.Column="3" Content="✕" FontSize="10"
                      Command="{Binding Owner.RemoveLayerCommand}" CommandParameter="{Binding}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                 Opacity="0.6" TextWrapping="Wrap" />
    </StackPanel>
  </DataTemplate>

  <local:ParameterTemplateSelector x:Key="ParameterTemplateSelector"
                                   NumberTemplate="{StaticResource NumberFieldTemplate}"
                                   EnumTemplate="{StaticResource EnumFieldTemplate}"
                                   BooleanTemplate="{StaticResource BooleanFieldTemplate}"
                                   TextTemplate="{StaticResource TextFieldTemplate}"
                                   LayerStackTemplate="{StaticResource LayerStackFieldTemplate}" />

  <!-- A single result table: title, header row, then data rows. Columns are dynamic. -->
  <DataTemplate x:Key="ResultTableTemplate">
    <StackPanel Spacing="4" Margin="0,8,0,8">
      <TextBlock Text="{Binding Title}" Style="{StaticResource SubtitleTextBlockStyle}" />
      <ItemsControl ItemsSource="{Binding Columns}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" Width="160" FontWeight="SemiBold" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <ItemsControl ItemsSource="{Binding Rows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ItemsControl ItemsSource="{Binding}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" Width="160" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </DataTemplate>

</ResourceDictionary>
