<Page x:Class="FtdOptima.App.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FtdOptima.App.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      NavigationCacheMode="Required"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />

    <!-- Editor templates, one per ParameterKind. Each binds the field's Value two-way. -->
    <DataTemplate x:Key="NumberFieldTemplate">
      <StackPanel Spacing="2" Margin="0,0,0,12">
        <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource CaptionTextBlockStyle}" />
        <NumberBox Value="{Binding Value, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
        <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.6" TextWrapping="Wrap" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EnumFieldTemplate">
      <StackPanel Spacing="2" Margin="0,0,0,12">
        <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource CaptionTextBlockStyle}" />
        <ComboBox ItemsSource="{Binding Options}"
                  SelectedItem="{Binding Value, Mode=TwoWay}"
                  HorizontalAlignment="Stretch" />
        <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.6" TextWrapping="Wrap" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="BooleanFieldTemplate">
      <StackPanel Spacing="2" Margin="0,0,0,12">
        <ToggleSwitch Header="{Binding DisplayLabel}" IsOn="{Binding Value, Mode=TwoWay}" />
        <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.6" TextWrapping="Wrap" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="TextFieldTemplate">
      <StackPanel Spacing="2" Margin="0,0,0,12">
        <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource CaptionTextBlockStyle}" />
        <TextBox Text="{Binding Value, Mode=TwoWay}" />
        <TextBlock Text="{Binding Help}" Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.6" TextWrapping="Wrap" />
      </StackPanel>
    </DataTemplate>

    <local:ParameterTemplateSelector x:Key="ParameterTemplateSelector"
                                     NumberTemplate="{StaticResource NumberFieldTemplate}"
                                     EnumTemplate="{StaticResource EnumFieldTemplate}"
                                     BooleanTemplate="{StaticResource BooleanFieldTemplate}"
                                     TextTemplate="{StaticResource TextFieldTemplate}" />

    <!-- A single result table: title, header row, then data rows. Columns are dynamic. -->
    <DataTemplate x:Key="ResultTableTemplate">
      <StackPanel Spacing="4" Margin="0,8,0,8">
        <TextBlock Text="{Binding Title}" Style="{StaticResource SubtitleTextBlockStyle}" />
        <ItemsControl ItemsSource="{Binding Columns}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" Width="160" FontWeight="SemiBold" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" Width="160" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>

    <!-- The whole runner panel for the selected module. -->
    <DataTemplate x:Key="RunnerTemplate">
      <ScrollViewer>
        <StackPanel Spacing="12" Margin="24" MaxWidth="640" HorizontalAlignment="Left">
          <TextBlock Text="{Binding Name}" Style="{StaticResource TitleTextBlockStyle}" />
          <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.75" />

          <TextBlock Text="Inputs" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
          <ItemsControl ItemsSource="{Binding Fields}"
                        ItemTemplateSelector="{StaticResource ParameterTemplateSelector}" />

          <Button Content="Compute" Command="{Binding ComputeCommand}"
                  Style="{StaticResource AccentButtonStyle}"
                  AutomationProperties.AutomationId="ComputeButton" />

          <TextBlock Text="{Binding ErrorMessage}" Foreground="OrangeRed"
                     TextWrapping="Wrap" />

          <StackPanel Spacing="8" Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Results" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <ItemsControl ItemsSource="{Binding Summary}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1" CornerRadius="8"
                          Padding="16,12" Margin="0,0,12,0" MinWidth="140">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Label}" Style="{StaticResource CaptionTextBlockStyle}"
                                 Opacity="0.7" />
                      <TextBlock Text="{Binding Value}" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding Tables}"
                          ItemTemplate="{StaticResource ResultTableTemplate}" />

            <TextBlock Text="{Binding Notes}" Opacity="0.6" FontStyle="Italic"
                       TextWrapping="Wrap" Margin="0,8,0,0" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>
  </Page.Resources>

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Master: discovered modules -->
    <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Text="{Binding Title}" Style="{StaticResource TitleTextBlockStyle}"
                 Margin="16,24,16,12" />
      <ListView Grid.Row="1"
                ItemsSource="{Binding Modules}"
                SelectedItem="{Binding SelectedModule, Mode=TwoWay}">
        <ListView.ItemTemplate>
          <DataTemplate>
            <StackPanel Spacing="2" Margin="0,8">
              <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>

    <!-- Detail: the selected module's generic form + results -->
    <ContentControl Grid.Column="1"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Content="{Binding Runner}"
                    ContentTemplate="{StaticResource RunnerTemplate}" />
  </Grid>
</Page>
