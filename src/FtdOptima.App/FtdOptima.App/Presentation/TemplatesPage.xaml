<Page x:Class="FtdOptima.App.Presentation.TemplatesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FtdOptima.App.Presentation"
      xmlns:utu="using:Uno.Toolkit.UI"
      NavigationCacheMode="Required"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <utu:NavigationBar Grid.Row="0" Content="{Binding Title}" />

    <Grid Grid.Row="1" Padding="24" ColumnSpacing="24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Design templates -->
      <Grid Grid.Column="0" RowSpacing="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Design templates" Style="{StaticResource SubtitleTextBlockStyle}" />
        <ListView Grid.Row="1" ItemsSource="{Binding DesignTemplates}"
                  SelectedItem="{Binding SelectedDesignTemplate, Mode=TwoWay}"
                  Background="{ThemeResource LayerFillColorDefaultBrush}">
          <ListView.ItemTemplate>
            <DataTemplate>
              <StackPanel Spacing="2" Margin="0,6">
                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="{Binding VehicleClass}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
        <Button Grid.Row="2" Content="Delete selected" Command="{Binding DeleteDesignTemplateCommand}" />
      </Grid>

      <!-- Module templates -->
      <Grid Grid.Column="1" RowSpacing="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Module templates" Style="{StaticResource SubtitleTextBlockStyle}" />
        <ListView Grid.Row="1" ItemsSource="{Binding ModuleTemplates}"
                  SelectedItem="{Binding SelectedModuleTemplate, Mode=TwoWay}"
                  Background="{ThemeResource LayerFillColorDefaultBrush}">
          <ListView.ItemTemplate>
            <DataTemplate>
              <StackPanel Spacing="2" Margin="0,6">
                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="{Binding SubsystemTypeId}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
        <Button Grid.Row="2" Content="Delete selected" Command="{Binding DeleteModuleTemplateCommand}" />
      </Grid>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Padding="24,0,24,16">
      <Button Content="◀ Back to designs" Command="{Binding BackCommand}" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Opacity="0.7" />
    </StackPanel>
  </Grid>
</Page>
